# CloudHost Environment Variables
# Created by Bruce Bera

# Server Configuration
NODE_ENV=production
PORT=3000
BASE_URL=https://cloudhost.app

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cloudhost

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# Admin Account (created automatically if not exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bera
ADMIN_EMAIL=admin@cloudhost.app

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# Payment Providers
# M-Pesa (PayHero)
PAYHERO_API_USERNAME=your_payhero_username
PAYHERO_API_PASSWORD=your_payhero_password
PAYHERO_CHANNEL_ID=your_channel_id

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cryptocurrency (Optional)
CRYPTO_WALLET_ADDRESS=your_wallet_address

# GitHub (for private repos)
GITHUB_TOKEN=ghp_your_github_token

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# WhatsApp (for admin notifications)
WHATSAPP_ADMIN_NUMBER=254712345678

# Redis (optional, for rate limiting)
REDIS_URL=redis://localhost:6379
